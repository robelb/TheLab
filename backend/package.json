{
  "name": "thelab-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express API for TheLab shop and brand extraction",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "embed": "tsx scripts/generate-embeddings.ts",
    "colors": "tsx scripts/generate-colors.ts",
    "extract": "tsx scripts/extract-brand.ts",
    "customize": "tsx scripts/generate-customized-images.ts",
    "fetch:catalogues": "tsx scripts/fetch-catalogues.ts",
    "flatten:catalogues": "tsx scripts/flatten-catalogues.ts",
    "feature": "tsx scripts/feature-products.ts",
    "reset:images": "tsx scripts/reset-generated-images.ts",
    "strip:gallery": "tsx scripts/strip-global-gallery.ts",
    "regenerate:images": "tsx scripts/regenerate-brand-images.ts",
    "demo:user": "tsx scripts/create-demo-user.ts"
  },
  "dependencies": {
    "@google/genai": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "openai": "^4.104.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}

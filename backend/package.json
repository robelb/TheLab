{
  "name": "thelab-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express API for TheLab shop and brand extraction",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "extract": "tsx scripts/extract-brand.ts"
  },
  "dependencies": {
    "@google/genai": "^1.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3"
  }
}

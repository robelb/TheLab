PORT=3001

# Neon PostgreSQL — https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Brand extraction — OpenAI is used when OPENAI_API_KEY is set; otherwise Gemini.
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Public base URL for customizedImage links written to the catalog
PUBLIC_API_URL=http://localhost:3001

# ── Supabase Storage (optional) ──────────────────────────────────────────────
# When set, uploaded product images and AI-generated photos are stored in
# Supabase Storage instead of on local disk. Leave blank to keep local storage.
# Supabase project → Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SERVICE ROLE key (server-side only — never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=
# Bucket name (created automatically as a public bucket if missing).
SUPABASE_STORAGE_BUCKET=product-images
